# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]in/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Visual Studio / Rider / IDE
.vs/
.vscode/
.idea/
*.csproj
*.unityproj
*.sln
# Unity/IDE-generated solution (references the gitignored *.csproj). The
# hand-written PitTycoon.Domain.slnx used by `dotnet test` stays tracked.
FestivalGame.slnx
*.suo
*.tmp
*.user
*.userprefs
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db
*.csproj.user

# Gradle cache
.gradle/

# Crashlytics
crashlytics-build.properties

# OS files
.DS_Store
Thumbs.db

# Tooling caches
.serena/
.claude/
.superpowers/

# Hand-written standalone Domain test project (outside Assets, not Unity-generated).
# The *.csproj rule above targets Unity-generated files; re-include ours.
!tests/**/*.csproj

tmp_blender/
